---
import { getLangFromUrl, useTranslations } from "@/i18n/utils";
import Translate from "@/icons/translate.astro";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const currentPath = Astro.url.pathname;

let toggleLanguage;
if (lang === "en") {
  toggleLanguage = currentPath === "/" ? "/es/" : `/es${currentPath}`;
} else {
  toggleLanguage = currentPath.replace(/^\/es/, "") || "/";
}

const links = [
  { name: t('nav.home'), href: lang === 'en' ? '/' : '/es/' },
  { name: t('nav.portfolio'), href: lang === 'en' ? '/portfolio' : '/es/portfolio' },
  { name: t('nav.blog'), href: lang === 'en' ? '/blog' : '/es/blog' },
  { name: t('nav.setup'), href: lang === 'en' ? '/setup' : '/es/setup' },
]
---

