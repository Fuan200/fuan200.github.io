        </svg>
      </a>
    </div>
    
  </div>
</section>

<style>
  .hero {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: calc(100vh - 130px);
    /* min-height: 100vh; */
    padding: 0 2rem;
    background: #121212;
  }

  .hero-content {
    text-align: center;
    max-width: 600px;
  }

  .hero-title {
    font-size: clamp(2.5rem, 8vw, 4rem);
    color: #c6ccd4;
    margin: 0 0 3rem 0;
    line-height: 1.2;
    letter-spacing: -0.02em;
    transition: all 0.4s ease;
  }

  .hero-title:hover {
    color: #ffffff;
    text-shadow: 0 0 10px #6666ff, 0 0 20px #6666ff, 0 0 40px #6666ff;
    transform: scale(1.025);
  }

  .social-links {
    display: flex;
    justify-content: center;
    gap: 2rem;
    margin-top: 2rem;
  }

  .social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 4rem;
    height: 4rem;
    color: #6b7280;
    text-decoration: none;
    border: 2px solid rgba(107, 114, 128, 0.3);
    border-radius: 1rem;
    transition: all 0.3s ease;
    position: relative;
    overflow: hidden;
  }

  .social-link::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(102, 102, 255, 0.1), transparent);
    transition: left 0.5s ease;
  }

  .social-link:hover::before {
    left: 100%;
  }

  .social-link:hover {
    color: #ffffff;
    border-color: #6666ff;
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(93, 93, 232, 0.2);
  }

  .social-link:active {
    transform: translateY(0);
  }

  @media (max-width: 768px) {
    .hero {
      padding: 0 1rem;
    }
    
    .social-links {
      gap: 1.5rem;
    }
    
    .social-link {
      width: 2.5rem;
      height: 2.5rem;
    }
  }
</style>