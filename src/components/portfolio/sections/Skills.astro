---
import Section from '@/components/Section.astro';
import type { ImageMetadata } from 'astro';

import { skills } from '@cv';
import Python from '@/icons/python.svg';
import Bash from '@/icons/bash.svg';
import JavaScript from '@/icons/javascript.svg';
import TypeScript from '@/icons/typescript.svg';
import HTML from '@/icons/html.svg';
import CSS from '@/icons/css.svg';
import Angular from '@/icons/angular.svg';
import AstroIcon from '@/icons/astro.svg';
import React from '@/icons/react.svg';
import Node from '@/icons/node.svg';
import Express from '@/icons/express.svg';
import NestJS from '@/icons/nestjs.svg';
import FastAPI from '@/icons/fastapi.svg';
import MySQL from '@/icons/mysql.svg';
import Postgres from '@/icons/postgres.svg';
import MongoDB from '@/icons/mongodb.svg';
import Azure from '@/icons/azure.svg';
import Cloudflare from '@/icons/cloudflare.svg';
import Firebase from '@/icons/firebase.svg';
import Docker from '@/icons/docker.svg';
import Git from '@/icons/git.svg';
import GitHub from '@/icons/github.svg';
import Linux from '@/icons/linux.svg';
import Debian from '@/icons/debian.svg';
import Ubuntu from '@/icons/ubuntu.svg';

const SKILLS_ICONS: Record<string, ImageMetadata> = {
    Python,
    Bash,
    JavaScript,
    TypeScript,
    HTML,
    CSS,
    Angular,
    Astro: AstroIcon,
    React,
    Node,
    Express,
    NestJS,
    FastAPI,
    MySQL,
    Postgres,
    MongoDB,
    Azure,
    Cloudflare,
    Firebase,
    Docker,
    Git,
    GitHub,
    Linux,
    Debian,
    Ubuntu,
};

const { currentLocale } = Astro;
const title = currentLocale === 'en' ? 'Skills' : 'Habilidades';
const visibleSkills = skills.filter(({ name }) => name in SKILLS_ICONS);
const carouselSkills = [...visibleSkills, ...visibleSkills];
---

<Section title={title}>
    <div class='skills-carousel' aria-label={title}>
        <ul class='skills-track'>
            {
                carouselSkills.map(({ name }, index) => {
                    const icon = SKILLS_ICONS[name];
                    const isClone = index >= visibleSkills.length;

                    return (
                        <li class='skill-chip' aria-hidden={isClone ? 'true' : 'false'}>
                            <span class='sr-only'>{name}</span>
                            {icon && (
                                <img
                                    class='skill-image'
                                    src={icon.src}
                                    width={icon.width}
                                    height={icon.height}
                                    alt=''
                                    loading='lazy'
                                    decoding='async'
                                />
                            )}
                        </li>
                    );
                })
            }
        </ul>
    </div>
</Section>

<style>
    .skills-carousel {
        --carousel-gap: 1rem;
        --carousel-duration: 40s;
        position: relative;
        overflow: hidden;
        width: 100%;
        padding-block: 0.5rem;
        mask-image: linear-gradient(
            to right,
            transparent 0,
            black 4%,
            black 96%,
            transparent 100%
        );
    }

    .skills-track {
        display: flex;
        align-items: center;
        gap: var(--carousel-gap);
        width: max-content;
        animation: skills-loop var(--carousel-duration) linear infinite;
    }

    .skill-chip {
        display: flex;
        align-items: center;
        justify-content: center;
        flex: 0 0 auto;
        width: clamp(4.25rem, 8vw, 5rem);
        height: clamp(4.25rem, 8vw, 5rem);
        border: 1px solid #202020;
        border-radius: 1.2rem;
        background:
            linear-gradient(180deg, rgba(255, 255, 255, 0.05), rgba(255, 255, 255, 0.015)),
            #292929;
        color: #fdfdfd;
        box-shadow: 0 12px 24px rgba(0, 0, 0, 0.16);
        transition:
            transform 0.2s ease,
            border-color 0.2s ease,
            background 0.2s ease;
    }

    .skill-image {
        width: 100%;
        height: 100%;
        object-fit: contain;
        display: block;
    }

    .skill-chip:hover {
        transform: translateY(-3px);
        border-color: #333;
        background:
            linear-gradient(180deg, rgba(255, 255, 255, 0.08), rgba(255, 255, 255, 0.03)),
            #303030;
    }

    .sr-only {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        white-space: nowrap;
        border: 0;
    }

    @keyframes skills-loop {
        from {
            transform: translateX(0);
        }
        to {
            transform: translateX(calc(-50% - (var(--carousel-gap) / 2)));
        }
    }

    @media (max-width: 768px) {
        .skills-carousel {
            --carousel-gap: 0.85rem;
            --carousel-duration: 22s;
            mask-image: linear-gradient(
                to right,
                transparent 0,
                black 4%,
                black 96%,
                transparent 100%
            );
        }

        .skill-chip {
            width: 4rem;
            height: 4rem;
            border-radius: 1rem;
        }
    }

    @media (prefers-reduced-motion: reduce) {
        .skills-carousel {
            overflow-x: auto;
            mask-image: none;
            scrollbar-width: none;
        }

        .skills-carousel::-webkit-scrollbar {
            display: none;
        }

        .skills-track {
            animation: none;
        }
    }
</style>
